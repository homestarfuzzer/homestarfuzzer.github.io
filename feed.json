---
layout: null
permalink: /feed.json
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ site.title | jsonify }},
  "home_page_url": {{ site.url | jsonify }},
  "feed_url": {{ site.url | append: "/feed.json" | jsonify }},
  "description": {{ site.description | jsonify }},
  "items": [
    {%- assign all_items = site.posts | concat: site.writeups | sort: 'date' | reverse -%}
    {%- for item in all_items %}
    {
      "id": {{ site.url | append: item.url | jsonify }},
      "url": {{ site.url | append: item.url | jsonify }},
      "title": {{ item.title | jsonify }},
      "summary": {{ item.excerpt | strip_html | strip | jsonify }},
      "date_published": {{ item.date | date_to_xmlschema | jsonify }},
      "type": {%- if item.collection == 'writeups' %} "writeup"{%- else %} "post"{%- endif %},
      "tags": {{ item.tags | jsonify }}
      {%- if item.platform %},
      "platform": {{ item.platform | jsonify }}
      {%- endif %}
      {%- if item.difficulty %},
      "difficulty": {{ item.difficulty | jsonify }}
      {%- endif %}
    }{%- unless forloop.last %},{%- endunless %}
    {%- endfor %}
  ]
}
